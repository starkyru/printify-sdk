{
  "name": "printify-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Printify API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": ["printify", "api", "print-on-demand"],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=18"
  }
}
