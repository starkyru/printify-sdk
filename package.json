{
  "name": "printify-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Printify API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepare": "husky",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "lint-staged": {
    "*.ts": "eslint"
  },
  "keywords": [
    "printify",
    "api",
    "print-on-demand"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=18"
  }
}
